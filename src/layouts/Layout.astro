---
import "../styles/global.css";
import type { Language } from "../utils/i18n";

const languages: Record<Language, Record<string, string>> = {
	fr: {
		title: "Paw & Ronrons - Cat-Sitting",
	},
	en: {
		title: "Paw & Ronrons - Cat-Sitting",
	},
}

const currentLanguage = Astro.currentLocale as Language
---

<!doctype html>
<html lang={currentLanguage} class="h-full w-full">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{languages[currentLanguage].title}</title>
	</head>
<script async src="https://www.googletagmanager.com/gtag/js?id=G-NWQV82BKJX"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-NWQV82BKJX');
</script>
	
	<body class="flex min-h-full w-full justify-center bg-white">
		<slot />
	</body>
</html>
