---
import type { Language } from "../utils/i18n";
import SectionTitle from "./SectionTitle.astro";

type i18nServices = {
  title: string;
  services: {
    title: string;
    description: string;
  }[];
};

const language: Record<Language, i18nServices> = {
  fr: {
    title: "Mes missions",
    services: [
      {
        title: "L'alimentation",
        description:
          "Les bols de nourritures sont nettoyées puis remplis en fonction du dosage demandé (croquettes et patées).",
      },
      {
        title: "La litière",
        description: "A chaque visite, la litière est nettoyée.",
      },
      {
        title: "L'hydratation",
        description:
          "Les bols d'eau sont nettoyés chaque jour et remplis en fonction des besoins. Les fontaines à eau tous les 2-3 jours selon leur état.",
      },
      {
        title: "Les petits plus",
        description: "L'arrosage des plantes et des petits conseils.",
      },
    ],
  },
  en: {
    title: "My services",
    services: [
      {
        title: "Feeding",
        description:
          "Food bowls are cleaned and refilled according to the requested portions (kibble and wet food).",
      },
      {
        title: "Litter box",
        description: "The litter box is cleaned during every visit.",
      },
      {
        title: "Hydration",
        description:
          "Water bowls are cleaned daily and refilled as needed. Water fountains are maintained every 2-3 days depending on their condition.",
      },
      {
        title: "Add",
        description: "Watering the plants and small tips.",
      },
    ],
  },
};

const currentLanguage = Astro.currentLocale as Language;
---

<section class="-mt-5 px-5 pt-[30px] pb-5">
  <SectionTitle marginTop={false}
    >{language[currentLanguage].title}</SectionTitle
  >

  <div class="mx-auto grid w-full grid-cols-2 gap-3">
    {
      language[currentLanguage].services.map((service, index) => {
        const alignments = [
          "text-left",
          "text-right",
          "text-left",
          "text-right",
        ];
        return (
          <div
            class:list={[
              "flex h-full flex-col justify-center rounded-2xl bg-white/60 p-4 shadow-[0_4px_16px_rgba(0,0,0,0.08)]",
              alignments[index],
            ]}
          >
            <h3 class="mb-1 text-lg font-bold text-center">{service.title}</h3>
            <p class="text-base leading-[1.3] text-center">{service.description}</p>
          </div>
        );
      })
    }
  </div>
</section>
